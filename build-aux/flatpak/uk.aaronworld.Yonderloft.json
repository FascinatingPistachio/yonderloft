{
  "id": "uk.aaronworld.Yonderloft",
  "runtime": "org.gnome.Platform",
  "runtime-version": "48",
  "sdk": "org.gnome.Sdk",
  "command": "yonderloft",
  "finish-args": [
    "--socket=wayland",
    "--socket=fallback-x11",
    "--device=dri",
    "--socket=pulseaudio",
    "--share=ipc",
    "--share=network",
    "--talk-name=org.freedesktop.Flatpak"
  ],
  "x-finish-args-note": "talk-name=org.freedesktop.Flatpak lets the 'client' runtime run downloaded native game clients on the host via flatpak-spawn --host. Electron/Chromium clients can't run nested inside this sandbox (they crash). This is a deliberate sandbox relaxation used only to launch those external clients.",
  "cleanup": [
    "/include",
    "/lib/pkgconfig",
    "/man",
    "/share/doc",
    "/share/gtk-doc",
    "*.la",
    "*.a"
  ],
  "modules": [
    {
      "name": "ruffle",
      "comment": "Bundled self-hosted Ruffle (Rust/WASM Flash emulator, MIT/Apache). The ruffle runtime resolves it at <pkgdatadir>/ruffle. Bump with build-aux/flatpak/update-ruffle.py.",
      "buildsystem": "simple",
      "build-commands": [
        "install -d /app/share/yonderloft/ruffle",
        "cp -r ./* /app/share/yonderloft/ruffle/"
      ],
      "sources": [
        {
          "type": "archive",
          "archive-type": "zip",
          "strip-components": 0,
          "url": "https://github.com/ruffle-rs/ruffle/releases/download/v0.3.0/ruffle-0.3.0-web-selfhosted.zip",
          "sha256": "9cdc5baac95dea452d2ef4a3859f3a4c8576dd3377bb40849e41fb6359170d7d",
          "x-checker-data": {
            "type": "json",
            "url": "https://api.github.com/repos/ruffle-rs/ruffle/releases/latest",
            "version-query": ".tag_name",
            "url-query": ".assets[] | select(.name | test(\"web-selfhosted.zip$\")) | .browser_download_url"
          }
        }
      ]
    },
    {
      "name": "yonderloft",
      "buildsystem": "meson",
      "sources": [
        {
          "type": "dir",
          "path": "../.."
        }
      ]
    }
  ]
}

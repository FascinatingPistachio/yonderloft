<component type="desktop-application">
  <id>uk.aaronworld.Yonderloft</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <name>Yonderloft</name>
  <summary>Launch community revival MMOs safely from one native app</summary>

  <description>
    <p>
      Yonderloft brings nostalgia back to life with a native launcher for fan-run
      and revival versions of childhood online games. It discovers live servers,
      chooses the best runtime automatically, and keeps every title isolated in
      its own sandboxed profile.
    </p>
    <p>
      Titles may use Flash, legacy runtime layers, or modern browser rewrites.
      Yonderloft handles the details so you can browse and play without manual
      runtime setup, profile collisions, or built-in telemetry.
    </p>
    <p>Key features:</p>
    <ul>
      <li>Live catalog of confirmed revival game servers</li>
      <li>Automatic runtime selection for Flash, web, and legacy clients</li>
      <li>Per-game sandboxed profiles with easy data clearing</li>
      <li>Remote catalog updates without requiring an app release</li>
      <li>Independent, privacy-friendly design with no telemetry</li>
    </ul>
    <p>
      Yonderloft is an independent project and is not affiliated with or endorsed
      by any rights holder or revival project. It does not host game content;
      it only connects to community-run servers.
    </p>
  </description>

  <launchable type="desktop-id">uk.aaronworld.Yonderloft.desktop</launchable>

  <screenshots>
    <screenshot type="default">https://raw.githubusercontent.com/FascinatingPistachio/yonderloft/main/data/screenshots/screenshot-1.png</screenshot>
    <screenshot>https://raw.githubusercontent.com/FascinatingPistachio/yonderloft/main/data/screenshots/screenshot-2.png</screenshot>
    <screenshot>https://raw.githubusercontent.com/FascinatingPistachio/yonderloft/main/data/screenshots/screenshot-3.png</screenshot>
  </screenshots>

  <!-- Screenshots are required for Flathub and must be real, fetchable images:
       appstreamcli compose downloads them and rejects the component if they
       404. Add them (hosted, or in-repo) before Flathub submission. -->

  <url type="homepage">https://aaronworld.uk/yonderloft</url>
  <url type="bugtracker">https://github.com/FascinatingPistachio/yonderloft/issues</url>
  <url type="vcs-browser">https://github.com/FascinatingPistachio/yonderloft</url>

  <developer id="uk.aaronworld">
    <name>Aaron</name>
  </developer>

  <content_rating type="oars-1.1">
    <content_attribute id="social-chat">intense</content_attribute>
    <content_attribute id="social-info">moderate</content_attribute>
  </content_rating>

  <branding>
    <color type="primary" scheme_preference="light">#FAF8F5</color>
    <color type="primary" scheme_preference="dark">#241F31</color>
  </branding>

  <categories>
    <category>Game</category>
  </categories>

  <keywords>
    <keyword>flash</keyword>
    <keyword>ruffle</keyword>
    <keyword>revival</keyword>
    <keyword>nostalgia</keyword>
    <keyword>online</keyword>
    <keyword>launcher</keyword>
  </keywords>

  <releases>
    <release version="0.1.0" date="2026-06-22" type="development">
      <description>
        <p>Pre-alpha release with a browsable revival games catalog, runtime
        auto-detection, isolated game profiles, and live status.</p>
      </description>
    </release>
  </releases>
</component>

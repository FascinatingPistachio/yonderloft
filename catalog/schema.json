{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gitlab.com/FascinatingPistachio/yonderloft/-/raw/main/catalog/schema.json",
  "title": "Yonderloft catalog manifest",
  "description": "The remote catalog of revival titles Yonderloft can launch.",
  "type": "object",
  "required": ["schema_version", "updated", "categories", "titles"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "description": "Catalog format version. The app refuses versions it doesn't understand.",
      "type": "integer",
      "const": 1
    },
    "updated": {
      "description": "Date the manifest was last edited (YYYY-MM-DD).",
      "type": "string",
      "format": "date"
    },
    "categories": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/category" }
    },
    "titles": {
      "type": "array",
      "items": { "$ref": "#/$defs/title" }
    }
  },
  "$defs": {
    "category": {
      "type": "object",
      "required": ["id", "name"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/slug" },
        "name": { "type": "string", "minLength": 1, "maxLength": 40 }
      }
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:[-_][a-z0-9]+)*$"
    },
    "url": {
      "type": "string",
      "format": "uri",
      "pattern": "^https?://"
    },
    "server": {
      "type": "object",
      "required": ["name", "url"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 40 },
        "url": { "$ref": "#/$defs/url" },
        "status_url": { "$ref": "#/$defs/url" },
        "default": { "type": "boolean" }
      }
    },
    "title": {
      "type": "object",
      "required": ["id", "name", "category", "runtime", "servers"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/slug" },
        "name": { "type": "string", "minLength": 1, "maxLength": 40 },
        "category": { "$ref": "#/$defs/slug" },
        "description": { "type": "string", "maxLength": 1000 },
        "art": {
          "description": "Cover/banner art: a path relative to the catalog root, or a full http(s) URL.",
          "type": "string",
          "pattern": "^(art/[A-Za-z0-9._-]+\\.(png|jpg|jpeg|webp|svg)|https?://.+)$"
        },
        "runtime": {
          "description": "Routing key — decides how the title is launched.",
          "type": "string",
          "enum": ["ruffle", "flash", "web", "client"]
        },
        "servers": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/server" }
        },
        "ruffle": { "$ref": "#/$defs/ruffleConfig" },
        "client": { "$ref": "#/$defs/clientConfig" },
        "player_selector": {
          "description": "CSS selector of the in-page game element to isolate to fill the window (web/ruffle titles).",
          "type": "string",
          "maxLength": 200
        },
        "tools": {
          "description": "Extra per-title web tools (e.g. an account register page), opened inside Yonderloft.",
          "type": "array",
          "items": { "$ref": "#/$defs/tool" }
        },
        "tags": {
          "type": "array",
          "items": { "type": "string", "minLength": 1, "maxLength": 24 },
          "uniqueItems": true
        },
        "notes": { "type": "string", "maxLength": 500 },
        "homepage": { "$ref": "#/$defs/url" }
      },
      "allOf": [
        {
          "if": { "properties": { "runtime": { "const": "client" } } },
          "then": { "required": ["client"] }
        }
      ]
    },
    "tool": {
      "type": "object",
      "required": ["name", "url"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 30 },
        "url": { "$ref": "#/$defs/url" },
        "icon": { "type": "string", "maxLength": 60 },
        "hide_selectors": {
          "type": "array",
          "items": { "type": "string", "minLength": 1, "maxLength": 200 }
        }
      }
    },
    "ruffleConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "swf_url": {
          "description": "Explicit SWF to load. null = let the page load its own.",
          "oneOf": [{ "$ref": "#/$defs/url" }, { "type": "null" }]
        },
        "flashvars": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "force_scale": {
          "type": "string",
          "enum": ["showAll", "noScale", "exactFit", "noBorder"]
        }
      }
    },
    "clientConfig": {
      "type": "object",
      "required": ["kind", "source_url"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["appimage_or_flatpak", "appimage", "flatpak", "tarball"]
        },
        "source_url": { "$ref": "#/$defs/url" },
        "install_hint": { "type": "string", "maxLength": 200 }
      }
    }
  }
}
